# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# Gmail sender credentials (use a Gmail App Password, not your account password)
# To generate an App Password: https://myaccount.google.com/apppasswords
EMAIL_SENDER_ADDRESS=your-email@gmail.com
EMAIL_SENDER_PASSWORD=your-gmail-app-password

# JWT signing key — shared across all services, must be at least 32 characters
# Generate a strong value with: openssl rand -base64 32
JWT_SECRET_KEY=replace-with-a-strong-random-secret-min-32-chars

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/account/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/account/{**catch-all}"
          }
        ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/order/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/order/{**catch-all}"
          }
        ]
      },
      "catalog-gift-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/gift/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/gift/{**catch-all}"
          }
        ]
      },
      "catalog-category-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/category/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/category/{**catch-all}"
          }
        ]
      },
      "catalog-donor-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/donor/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/donor/{**catch-all}"
          }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/notification/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/notification/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authenticationservice:8080/"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://orderservice:8080/"
          }
        }
      },
      "catalog-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:03",
            "Timeout": "00:00:02",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://catalogservice:8080/"
          },
          "destination2": {
            "Address": "http://catalogservice2:8080/"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notificationservice:8080/"
          }
        }
      }
    }
  }
}